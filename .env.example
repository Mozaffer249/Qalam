# =============================================================================
# Qalam — environment file for Docker Compose
# Copy to .env in the SAME directory as docker-compose.yml / docker-compose.prod.yml:
#   cp .env.example .env && chmod 600 .env && nano .env
# Never commit .env (secrets). This file is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED for: docker compose -f docker-compose.prod.yml up -d --build
# -----------------------------------------------------------------------------

# SQL Server — used by BOTH qalam-api (dbcontext) and messaging-api (MessagingDb).
# Must start with Server= or Data Source=
DB_CONNECTION_STRING=

# Same key as any existing encrypted DB columns; do not rotate without a migration plan.
ENCRYPTION_KEY=

# Long random string (e.g. openssl rand -base64 48)
JWT_SECRET=

# Must match RabbitMQ broker user/password in compose (default user name is qalam).
RABBITMQ_USER=qalam
RABBITMQ_PASS=

# Comma-separated browser origins (scheme + host + port). Required for Docker frontends on 8090/8091.
CORS_ALLOWED_ORIGINS=http://localhost:8090,http://localhost:8091,http://localhost:3005,http://localhost:3000

# SMTP — wired into messaging-api only (login OTP and queued mail).
# Provider: dmail.sa — outgoing mail.dmail.sa port 465 (SslOnConnect).
EMAIL_HOST=mail.dmail.sa
EMAIL_PORT=465
EMAIL_ENABLE_SSL=true
EMAIL_SECURE_SOCKET_MODE=SslOnConnect
EMAIL_FROM_NAME=Qalam Learning Platform
EMAIL_FROM_EMAIL=info@qalam.net.sa
EMAIL_USERNAME=info@qalam.net.sa
EMAIL_PASSWORD=

# -----------------------------------------------------------------------------
# OPTIONAL (defaults in compose or unused until you enable features)
# -----------------------------------------------------------------------------

EMAIL_DEFAULT_STRATEGY=Queued

# Web app base URL for login links in teacher lifecycle emails (prod default).
PLATFORM_WEB_APP_BASE_URL=https://qalam.net.sa/
# Public API origin for absolute-izing relative upload paths (course images, etc.).
# Local Docker default matches mapped port 8080. Staging/prod: https://api-staging.qalam.net.sa / https://api.qalam.net.sa
PLATFORM_API_PUBLIC_BASE_URL=http://localhost:8080

JWT_ISSUER=QalamProject
JWT_AUDIENCE=QalamProjectUsers

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Firebase push (path inside container if you mount a JSON key file)
FIREBASE_KEY_PATH=
FIREBASE_PROJECT_ID=

# Alibaba OSS (SAU Riyadh / me-central-1)
# Shared credentials; two logical buckets (identities + learning). To add another domain later:
#   OSS_<NAME>_BUCKET + OSS_<NAME>_PUBLIC_BASE_URL, OssBucketKeys.<Name>, consumer Upload(..., key)
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_REGION=me-central-1
OSS_ENDPOINT=https://oss-me-central-1.aliyuncs.com
OSS_USE_INTERNAL_ENDPOINT=false
OSS_ECS_ROLE_NAME=

# identities — teacher docs, profile pics
OSS_BUCKET=auth-and-identities-certificates-staging
OSS_PUBLIC_BASE_URL=https://auth-and-identities-certificates-staging.oss-me-central-1.aliyuncs.com

# learning — content library, open-session attachments (prod: qalam-content-prod)
OSS_LEARNING_BUCKET=qalam-content-dev
OSS_LEARNING_PUBLIC_BASE_URL=https://qalam-content-dev.oss-me-central-1.aliyuncs.com

# -----------------------------------------------------------------------------
# Frontend apps (docker-compose services)
# Source code now lives in this monorepo as git submodules:
#   apps/admin    → github.com/Mozaffer249/qalam-admin
#   apps/teacher  → github.com/Mozaffer249/qalam-teacher
# Run `git submodule update --init --recursive` after cloning so the
# directories are populated before `docker compose build`.
#
# The *_APP_PATH overrides below are ONLY needed for legacy servers where
# the frontends live outside the monorepo (e.g. /opt/qalam-admin). Leave
# them unset to use the in-repo paths (./apps/admin and ./apps/teacher).
# -----------------------------------------------------------------------------
# TEACHER_APP_PATH=/opt/qalam-teacher
# TEACHER_BUILD_MODE=production          # or staging → npm run build -- --mode staging
# ADMIN_APP_PATH=/opt/qalam-admin
ADMIN_API_URL=http://localhost:8080
TEACHER_API_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Local dev only (docker-compose.yml defaults) — not used by prod compose paths
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost

# Local service URLs (used by docker build args and local frontends)
# API (qalam-api):           http://localhost:8080
# Admin docker:              http://localhost:8090
# Teacher docker:            http://localhost:8091
# SQL Server (override):     localhost:1433
# Admin npm run dev:         http://localhost:3005
API_PORT=8080
ADMIN_PORT=8090
TEACHER_PORT=8091
SQLSERVER_PORT=1433
ADMIN_DEV_PORT=3005
API_DEV_PORT=62900
MESSAGING_API_DEV_PORT=62901
API_DEV_URL=http://localhost:62900
MESSAGING_API_DEV_URL=http://localhost:62901
ADMIN_API_URL=http://localhost:8080
TEACHER_API_URL=http://localhost:8080
