# ===========================================
# Qalam Production Environment Variables
# Copy this to .env and fill in real values
# ===========================================

# Database
DB_CONNECTION_STRING=

# Encryption (EF Core column encryption - DO NOT change after data is encrypted)
ENCRYPTION_KEY=

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=

# JWT
JWT_SECRET=
JWT_ISSUER=QalamProject
JWT_AUDIENCE=QalamProjectUsers

# CORS (comma-separated frontend URLs)
CORS_ALLOWED_ORIGINS=

# Email (SMTP)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_FROM_NAME=
EMAIL_FROM_EMAIL=
EMAIL_USERNAME=
EMAIL_PASSWORD=

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Firebase Push (optional)
FIREBASE_KEY_PATH=
FIREBASE_PROJECT_ID=

# Wasabi Storage (optional)
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_BUCKET=
WASABI_REGION=
WASABI_SERVICE_URL=
