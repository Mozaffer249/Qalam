# =============================================================================
# Qalam — STAGING environment file for the staging docker-compose stack.
# Copy on the VPS:
#   cp .env.staging.example /opt/qalam-staging/.env.staging && chmod 600 /opt/qalam-staging/.env.staging && nano .env.staging
# Never commit the populated file. This template is safe to commit.
# Bring up:
#   docker compose -f docker-compose.staging.yml -p qalam-staging --env-file .env.staging up -d --build
# =============================================================================

# -----------------------------------------------------------------------------
# Database connection strings.
# Native SQL Server on the same VPS, loopback only; containers use host.docker.internal.
# qalam_staging_user is dbo on qalam_staging only (separate from prod).
# -----------------------------------------------------------------------------
DB_CONNECTION_STRING=Server=host.docker.internal,1433;Database=qalam_staging;User Id=qalam_staging_user;Password=REPLACE_ME;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;
MESSAGING_DB_CONNECTION_STRING=Server=host.docker.internal,1433;Database=qalam_messaging_staging;User Id=qalam_staging_user;Password=REPLACE_ME;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# -----------------------------------------------------------------------------
# Migration & seed policy — staging is permissive on purpose.
# -----------------------------------------------------------------------------
MIGRATE_ON_STARTUP=true
SEED_DEFAULT_ADMIN=true
DEFAULT_ADMIN_EMAIL=admin@staging.qalam.net.sa
DEFAULT_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Secrets — generate a SEPARATE set from prod (never reuse).
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=
JWT_SECRET=
JWT_ISSUER=QalamProject-Staging
JWT_AUDIENCE=QalamProjectUsers-Staging

# RabbitMQ broker creds (Docker-internal).
RABBITMQ_USER=qalam
RABBITMQ_PASS=

# -----------------------------------------------------------------------------
# CORS — staging frontend origins (HTTPS only).
# No landing-page origin: the public landing at qalam.net.sa is prod-only by design.
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://teacher-staging.qalam.net.sa,https://admin-staging.qalam.net.sa

# -----------------------------------------------------------------------------
# Email (SMTP). Often you'll point staging at a sandbox mailbox (Mailtrap, MailHog) instead of real SMTP.
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_FROM_NAME=Qalam (staging)
EMAIL_FROM_EMAIL=
EMAIL_USERNAME=
EMAIL_PASSWORD=

# -----------------------------------------------------------------------------
# Optional integrations — leave blank to disable.
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

FIREBASE_KEY_PATH=
FIREBASE_PROJECT_ID=

WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_BUCKET=qalam-storage-staging
WASABI_REGION=ap-southeast-1
WASABI_SERVICE_URL=https://s3.ap-southeast-1.wasabisys.com
