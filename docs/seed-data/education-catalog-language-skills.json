          "filterOptionsVerify": "GET /Api/V1/Education/filter-options?domainId={{domainId}}&levelId={{levelId}} ГўвҖ вҖҷ nextStep Subject",
          "notes": "Seeded examples include English, French, German. levelId required when rule.hasEducationLevel."
        },
        {
          "step": "Unit",
          "endpoint": "POST /Api/V1/Content/Units",
          "bodyTemplate": {
            "nameAr": "Ш·В§ШёвҖһШёЛҶШ·ВӯШ·ВҜШ·В© 1 ГўвӮ¬вҖқ Ш·В§ШёвҖһШ·ЪҫШ·ВӯШёЩ№Ш·В§Ш·Ъҫ",
            "nameEn": "Module 1 ГўвӮ¬вҖқ Greetings",
            "subjectId": "{{subjectId}}",
            "termId": null,
            "orderIndex": 1,
            "unitTypeCode": "LanguageModule"
          },
          "typicalIdsExample": {
            "subjectId": "{{from Subject POST response id}}"
          },
          "filterOptionsVerify": "GET /Api/V1/Education/filter-options?domainId={{domainId}}&levelId={{levelId}}&subjectId={{subjectId}} ГўвҖ вҖҷ unit[] contains new module",
          "notes": "Must use LanguageModule; termId null."
        },
        {
          "step": "Lesson",
          "endpoint": "POST /Api/V1/Content/Lessons",
          "bodyTemplate": {
            "nameAr": "Ш·В§ШёвҖһШ·ВҜШ·ВұШ·Ві 1 ГўвӮ¬вҖқ ШёвҖҰШ·ВұШ·ВӯШ·ВЁШ·В§ШёвҖ№",
            "nameEn": "Lesson 1 ГўвӮ¬вҖқ Hello",
            "unitId": "{{unitId}}",
            "orderIndex": 1
          },
          "typicalIdsExample": {
            "unitId": "{{from Unit POST response id}}"
          },
          "filterOptionsVerify": "GET /Api/V1/Education/filter-options?...&subjectId={{subjectId}}&contentUnitId={{unitId}} ГўвҖ вҖҷ nextStep Lesson",
          "notes": "Select unit in admin tree before listing/creating lessons."
        }
      ]
    },
    "skills": {
      "chainDescription": "Subject ГўвҖ вҖҷ Unit (LanguageModule) ГўвҖ вҖҷ Lesson",
      "steps": [
        {
          "step": "Subject",
          "endpoint": "POST /Api/V1/Subjects",
          "bodyTemplate": {
            "nameAr": "ШёвҖҰШёвҖЎШ·В§Ш·ВұШ·В§Ш·Ъҫ Ш·В§ШёвҖһШ·В№Ш·ВұШ·В¶ ШёЛҶШ·В§ШёвҖһШ·ЪҫШёвҖҡШ·ВҜШёЩ№ШёвҖҰ",
            "nameEn": "Presentation Skills",
            "descriptionAr": "Ш·ЪҫШ·В·ШёЛҶШёЩ№Ш·Вұ ШёвҖҰШёвҖЎШ·В§Ш·ВұШ·В§Ш·Ъҫ Ш·В§ШёвҖһШ·ЪҫШ·ВӯШ·ВҜШ·В« Ш·ВЈШёвҖҰШ·В§ШёвҖҰ Ш·В§ШёвҖһШ·В¬ШёвҖҰШёвҖЎШёЛҶШ·Вұ",
            "descriptionEn": "Developing public speaking and presentation skills",
            "domainId": "{{domainId}}",
            "curriculumId": null,
            "levelId": null,
            "gradeId": null,
            "termId": null,
            "isActive": true
          },
          "typicalIdsExample": {
            "domainId": 4
          },
          "filterOptionsVerify": "GET /Api/V1/Education/filter-options?domainId={{domainId}} ГўвҖ вҖҷ nextStep Subject",
          "notes": "Seeded examples: Communication Skills, Critical Thinking, Time Management."
        },
        {
          "step": "Unit",
          "endpoint": "POST /Api/V1/Content/Units",
          "bodyTemplate": {
            "nameAr": "Ш·В§ШёвҖһШёЛҶШ·ВӯШ·ВҜШ·В© 1 ГўвӮ¬вҖқ Ш·ВЈШ·ВіШ·В§Ш·ВіШёЩ№Ш·В§Ш·Ъҫ Ш·В§ШёвҖһШ·В№Ш·ВұШ·В¶",
