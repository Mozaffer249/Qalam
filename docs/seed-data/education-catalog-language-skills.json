          "endpoint": "POST /Api/V1/Content/Lessons",
          "bodyTemplate": {
            "nameAr": "Ш·В§ШёвҖһШ·ВҜШ·ВұШ·Ві 1 ГўвӮ¬вҖқ ШёвҖЎШёЩ№ШёЖ’ШёвҖһ Ш·В§ШёвҖһШ·В№Ш·ВұШ·В¶",
