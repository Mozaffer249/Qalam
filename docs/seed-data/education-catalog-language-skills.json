          "notes": "No curriculumId. Seeded examples: Beginner Level, Intermediate Level, Advanced Level."
        },
        {
          "step": "Subject",
          "endpoint": "POST /Api/V1/Subjects",
          "bodyTemplate": {
            "nameAr": "Ш·В§ШёвҖһШ·ВҘШ·ВіШ·ВЁШ·В§ШёвҖ ШёЩ№Ш·В©",
            "nameEn": "Spanish",
            "descriptionAr": "Ш·ЪҫШ·В№ШёвҖһШёвҖҰ Ш·В§ШёвҖһШёвҖһШ·ШӣШ·В© Ш·В§ШёвҖһШ·ВҘШ·ВіШ·ВЁШ·В§ШёвҖ ШёЩ№Ш·В©",
