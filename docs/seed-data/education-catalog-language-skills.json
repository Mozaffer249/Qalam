{
  "description": "Hand-add catalog samples for Language and Skills domains. Resolve domainId from GET /Api/V1/Education/Domains ГўвӮ¬вҖқ typical fresh seed: language=3, skills=4 (insertion order in EducationDomainsSeeder). Remote or customized DBs may differ.",
  "idResolution": {
    "steps": [
      "GET /Api/V1/Education/Domains ГўвӮ¬вҖқ map code (language | skills) to id",
      "Admin UI: open /domains/{domainId}/tree ГўвӮ¬вҖқ click canvas node, list via filter-options, Add opens create drawer",
      "After each POST, refresh step panel or GET filter-options with parent ids to verify nextStep and list",
      "Replace {{placeholders}} in bodyTemplate with ids returned from create responses or filter-options lists"
    ],
    "adminTreeUrls": {
      "language": "/domains/{languageDomainId}/tree",
      "skills": "/domains/{skillsDomainId}/tree"
    },
    "localDev": {
      "apiBase": "http://localhost:8080",
      "adminDev": "http://localhost:3005",
      "auth": "Bearer <admin-jwt> on all POSTs"
    }
  },
  "domainReference": {
    "language": {
      "typicalDomainId": 3,
      "code": "language",
      "nameEn": "Languages",
      "wizardSteps": ["Level", "Subject", "Unit", "Lesson"],
      "educationRule": {
        "hasCurriculum": false,
        "hasEducationLevel": true,
        "hasGrade": false,
        "hasAcademicTerm": false,
        "hasContentUnits": true,
        "hasLessons": true
      },
      "createEndpoints": {
        "Level": "POST /Api/V1/Education/Levels",
        "Subject": "POST /Api/V1/Subjects",
        "Unit": "POST /Api/V1/Content/Units",
        "Lesson": "POST /Api/V1/Content/Lessons"
      },
      "seededBy": [
        "Qalam.Infrastructure/Seeding/LanguageLevelsSeeder.cs",
        "Qalam.Infrastructure/Seeding/LanguageSubjectsSeeder.cs",
        "Qalam.Infrastructure/Seeding/LanguageSkillsCatalogSeeder.cs"
      ],
      "notes": "DB seeds all ~161 language subjects with LanguageModule units (1 per subject) and 2 lessons each. Spanish/English Conversation A1 use curated module names; others use a default Introduction template. JSON samples add additional rows for testing admin tree."
    },
    "skills": {
      "typicalDomainId": 4,
      "code": "skills",
      "nameEn": "General Skills",
      "wizardSteps": ["Subject", "Unit", "Lesson"],
      "educationRule": {
        "hasCurriculum": false,
        "hasEducationLevel": false,
        "hasGrade": false,
        "hasAcademicTerm": false,
        "hasContentUnits": true,
        "hasLessons": true
      },
      "createEndpoints": {
        "Subject": "POST /Api/V1/Subjects",
        "Unit": "POST /Api/V1/Content/Units",
        "Lesson": "POST /Api/V1/Content/Lessons"
      },
      "seededBy": [
        "Qalam.Infrastructure/Seeding/GeneralSkillsSubjectsSeeder.cs",
        "Qalam.Infrastructure/Seeding/LanguageSkillsCatalogSeeder.cs"
      ],
      "notes": "DB seeds all 30 skills subjects with LanguageModule units (1 per subject) and 2 lessons each. Communication Skills and Public Speaking & Presentation use curated names; others use a default Foundations template. JSON samples add additional rows. Use unitTypeCode LanguageModule (no termId)."
    }
  },
  "unitTypeCodeReference": {
    "LanguageModule": "Language domain units; termId must be null",
    "SchoolUnit": "School units; termId required ГўвӮ¬вҖқ avoid for skills/language hand-add",
    "QuranSurah": "Quran only",
    "QuranPart": "Quran only"
  },
  "samplesByDomain": {
    "language": {
      "chainDescription": "Level ГўвҖ вҖҷ Subject ГўвҖ вҖҷ Unit (LanguageModule) ГўвҖ вҖҷ Lesson",
      "steps": [
        {
          "step": "Level",
          "endpoint": "POST /Api/V1/Education/Levels",
          "bodyTemplate": {
            "nameAr": "ШёвҖҰШ·ВіШ·ЪҫШёЛҶШёвҖ° ШёвҖҰШ·ВӯШ·В§Ш·ВҜШ·В«Ш·В©",
            "nameEn": "Conversation Level",
