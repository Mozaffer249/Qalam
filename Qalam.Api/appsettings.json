{
  "ConnectionStrings": {
    "dbcontext": ""
  },
  "Serilog": {
    "Using": [],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:4200"
    ]
  },
  "jwtSettings": {
    "Secret": "",
    "Issuer": "QalamProject",
    "Audience": "QalamProjectUsers",
    "AccessTokenExpireDate": 60,
    "RefreshTokenExpireDate": 43200,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifeTime": true,
    "ValidateIssuerSigningKey": true
  },
  "EmailSettings": {
    "Host": "",
    "Port": 587,
    "FromName": "",
    "FromEmail": "",
    "UserName": "",
    "Password": "",
    "EnableSsl": true,
    "DefaultStrategy": "Queued"
  },
  "SmsSettings": {
    "AccountSid": "",
    "AuthToken": "",
    "FromNumber": ""
  },
  "PushNotificationSettings": {
    "ServiceAccountKeyPath": "",
    "ProjectId": ""
  },
  "EnrollmentSettings": {
    "PaymentDeadlineHours": 48,
    "ExpirationCheckIntervalMinutes": 5
  },
  "EncryptionSettings": {
    "Key": ""
  },
  "RabbitMQSettings": {
    "HostName": "",
    "Port": 5672,
    "UserName": "",
    "Password": "",
    "VirtualHost": "/",
    "EmailQueueName": "email-queue",
    "SmsQueueName": "sms-queue",
    "PushQueueName": "push-queue",
    "TeacherDocUploadQueueName": "teacher-doc-upload-queue",
    "ProfilePicUploadQueueName": "profile-pic-upload-queue"
  },
  "RateLimiting": {
    "Login": {
      "MaxAttempts": 5,
      "WindowMinutes": 15
    },
    "Register": {
      "MaxAttempts": 3,
      "WindowMinutes": 60
    },
    "PasswordReset": {
      "MaxAttempts": 3,
      "WindowMinutes": 60
    },
    "RefreshToken": {
      "MaxAttempts": 10,
      "WindowMinutes": 1
    }
  },
  "PasswordPolicy": {
    "MinimumLength": 8,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSpecialCharacter": true,
    "PreventPasswordReuse": 5,
    "PasswordExpiryDays": 90,
    "CheckCommonPasswords": true
  },
  "SecuritySettings": {
    "SessionTimeout": {
      "Enabled": true,
      "InactivityMinutes": 480,
      "CheckIntervalMinutes": 5
    },
    "RiskBasedAuth": {
      "Enabled": true,
      "MaxFailedAttemptsPerIp": 10,
      "FailedAttemptWindowMinutes": 60,
      "RequireTwoFactorForSuspiciousIp": true,
      "BlockSuspiciousIpMinutes": 30
    },
    "EmailNotifications": {
      "Enabled": true,
      "NotifyOnNewDeviceLogin": true,
      "NotifyOnPasswordChange": true,
      "NotifyOnSessionTerminated": true,
      "NotifyOnSuspiciousActivity": true
    }
  }
}