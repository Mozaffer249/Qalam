{
  "ConnectionStrings": {
    "MessagingDb": ""
  },
  "Serilog": {
    "Using": [],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/messaging-log-.txt",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EmailSettings": {
    "Host": "",
    "Port": 587,
    "FromName": "",
    "FromEmail": "",
    "UserName": "",
    "Password": "",
    "EnableSsl": true,
    "DefaultStrategy": "Queued"
  },
  "SmsSettings": {
    "AccountSid": "",
    "AuthToken": "",
    "FromNumber": ""
  },
  "PushNotificationSettings": {
    "ServiceAccountKeyPath": "",
    "ProjectId": ""
  },
  "RabbitMQSettings": {
    "HostName": "",
    "Port": 5672,
    "UserName": "",
    "Password": "",
    "VirtualHost": "/",
    "EmailQueueName": "email-queue",
    "SmsQueueName": "sms-queue",
    "PushQueueName": "push-queue",
    "TeacherDocUploadQueueName": "teacher-doc-upload-queue",
    "ProfilePicUploadQueueName": "profile-pic-upload-queue",
    "OpenSessionRequestAttachmentUploadQueueName": "open-session-request-attachment-upload-queue",
    "TeacherContentFileUploadQueueName": "teacher-content-file-upload-queue"
  },
  "OssSettings": {
    "AccessKeyId": "",
    "AccessKeySecret": "",
    "BucketName": "auth-and-identities-certificates-staging",
    "Region": "me-central-1",
    "Endpoint": "https://oss-me-central-1.aliyuncs.com",
    "PublicBaseUrl": "https://auth-and-identities-certificates-staging.oss-me-central-1.aliyuncs.com",
    "LearningBucketName": "qalam-content-dev",
    "LearningPublicBaseUrl": "https://qalam-content-dev.oss-me-central-1.aliyuncs.com",
    "UseInternalEndpoint": false
  }
}


