# =============================================================================
# Qalam — PRODUCTION environment file for the prod docker-compose stack.
# Copy on the VPS:
#   cp .env.prod.example .env.prod && chmod 600 .env.prod && nano .env.prod
# Never commit the populated file. This template is safe to commit.
# Bring up:
#   docker compose -f docker-compose.prod.yml -p qalam-prod --env-file .env.prod up -d --build
# =============================================================================

# -----------------------------------------------------------------------------
# Database connection strings.
# SQL Server is natively installed on the VPS, listening on 127.0.0.1:1433.
# Containers reach it via host.docker.internal (provided by extra_hosts in compose).
# Use a strong per-environment password; the qalam_prod_user is dbo on qalam_prod only.
# -----------------------------------------------------------------------------
DB_CONNECTION_STRING=Server=host.docker.internal,1433;Database=qalam_prod;User Id=qalam_prod_user;Password=REPLACE_ME;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;
MESSAGING_DB_CONNECTION_STRING=Server=host.docker.internal,1433;Database=qalam_messaging_prod;User Id=qalam_prod_user;Password=REPLACE_ME;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# -----------------------------------------------------------------------------
# Migration & seed policy.
# Default for prod: no auto-migration. Flip MIGRATE_ON_STARTUP=true only for a one-off migrate run,
# then flip back to false (see docs/OPERATIONS_RUNBOOK.md for the manual migrate procedure).
# Default-admin seeding: set SEED_DEFAULT_ADMIN=true ONLY for the very first boot, capture the password,
# then set back to false on subsequent boots.
# -----------------------------------------------------------------------------
MIGRATE_ON_STARTUP=false
SEED_DEFAULT_ADMIN=false
DEFAULT_ADMIN_EMAIL=admin@qalam.net.sa
DEFAULT_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Secrets. Generate fresh values per environment (don't reuse from staging).
#   ENCRYPTION_KEY:  32-byte hex (openssl rand -hex 16)
#   JWT_SECRET:      48-byte base64 (openssl rand -base64 48)
# Rotate via OPERATIONS_RUNBOOK.md.
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=
JWT_SECRET=
JWT_ISSUER=QalamProject
JWT_AUDIENCE=QalamProjectUsers

# RabbitMQ broker creds (Docker-internal; never exposed publicly).
RABBITMQ_USER=qalam
RABBITMQ_PASS=

# -----------------------------------------------------------------------------
# CORS — your real prod frontend origins, HTTPS only, comma-separated.
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://qalam.net.sa,https://teacher.qalam.net.sa,https://admin.qalam.net.sa

# -----------------------------------------------------------------------------
# Email (SMTP). Used for OTP, password reset, security notifications.
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_FROM_NAME=Qalam
EMAIL_FROM_EMAIL=
EMAIL_USERNAME=
EMAIL_PASSWORD=

# -----------------------------------------------------------------------------
# Optional integrations — leave blank to disable cleanly.
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

FIREBASE_KEY_PATH=
FIREBASE_PROJECT_ID=

WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_BUCKET=qalam-storage-prod
WASABI_REGION=ap-southeast-1
WASABI_SERVICE_URL=https://s3.ap-southeast-1.wasabisys.com
