{
	"info": {
		"_postman_id": "admin-teacher-mgmt-001",
		"name": "Admin - Teacher Management",
		"description": "Admin endpoints for managing teacher verification, document approval/rejection, and account blocking",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{admin_access_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5000",
			"type": "string"
		},
		{
			"key": "admin_access_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "teacher_id",
			"value": "1",
			"type": "string"
		},
		{
			"key": "document_id",
			"value": "1",
			"type": "string"
		},
		{
			"key": "teacher_subject_id",
			"value": "1",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Queries",
			"item": [
				{
					"name": "Get Teachers (paginated)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/Teachers?pageNumber=1&pageSize=10",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"Teachers"
							],
							"query": [
								{
									"key": "pageNumber",
									"value": "1"
								},
								{
									"key": "pageSize",
									"value": "10"
								},
								{
									"key": "status",
									"value": "Active",
									"description": "AwaitingDocuments | PendingVerification | DocumentsRejected | Active | Blocked",
									"disabled": true
								},
								{
									"key": "location",
									"value": "1",
									"description": "TeacherLocation",
									"disabled": true
								},
								{
									"key": "subjectId",
									"value": "1",
									"disabled": true
								},
								{
									"key": "search",
									"value": "ahmed",
									"disabled": true
								},
								{
									"key": "sortBy",
									"value": "1",
									"description": "1=Newest, 2=NameAsc, 3=Status",
									"disabled": true
								}
							]
						},
						"description": "Paginated browse of all teachers with optional filters"
					},
					"response": []
				},
				{
					"name": "Get Pending Teachers",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/Pending?pageNumber=1&pageSize=10",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"Pending"
							],
							"query": [
								{
									"key": "pageNumber",
									"value": "1",
									"description": "Page number (default: 1)"
								},
								{
									"key": "pageSize",
									"value": "10",
									"description": "Number of items per page (default: 10)"
								}
							]
						},
						"description": "Get paginated list of teachers pending verification or with rejected documents"
					},
					"response": []
				},
				{
					"name": "Get Teacher Details",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/{{teacher_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"{{teacher_id}}"
							]
						},
						"description": "Get teacher details with all documents for admin review"
					},
					"response": []
				},
				{
					"name": "List Teacher Subjects (global)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/Subjects?pageNumber=1&pageSize=10",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"Subjects"
							],
							"query": [
								{
									"key": "pageNumber",
									"value": "1"
								},
								{
									"key": "pageSize",
									"value": "10"
								},
								{
									"key": "teacherId",
									"value": "{{teacher_id}}",
									"disabled": true
								},
								{
									"key": "verificationStatus",
									"value": "2",
									"description": "DocumentVerificationStatus: 2=Approved",
									"disabled": true
								}
							]
						},
						"description": "Paginated list of teacher subjects across all teachers"
					},
					"response": []
				},
				{
					"name": "Get Teacher Subjects",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/{{teacher_id}}/Subjects",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"{{teacher_id}}",
								"Subjects"
							]
						},
						"description": "All teaching subjects for a teacher (active, inactive, rejected)"
					},
					"response": []
				},
				{
					"name": "Get Teacher Subject By Id",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/{{teacher_id}}/Subjects/{{teacher_subject_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"{{teacher_id}}",
								"Subjects",
								"{{teacher_subject_id}}"
							]
						},
						"description": "Single teacher subject with units"
					},
					"response": []
				}
			],
			"description": "Query endpoints for retrieving teacher information"
		},
		{
			"name": "Commands",
			"item": [
				{
					"name": "Activate Teacher Account",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/{{teacher_id}}/Activate",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"{{teacher_id}}",
								"Activate"
							]
						},
						"description": "Authorize teacher account when canBeActivated is true (all docs and subjects approved, at least 1 subject)."
					},
					"response": []
				},
				{
					"name": "Approve Document",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/{{teacher_id}}/Documents/{{document_id}}/Approve",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"{{teacher_id}}",
								"Documents",
								"{{document_id}}",
								"Approve"
							]
						},
						"description": "Approve a specific document for a teacher. Does not activate account — use Activate Teacher Account when canBeActivated is true."
					},
					"response": []
				},
				{
					"name": "Reject Document",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"reason\": \"The document is unclear. Please upload a high-quality scan.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/{{teacher_id}}/Documents/{{document_id}}/Reject",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"{{teacher_id}}",
								"Documents",
								"{{document_id}}",
								"Reject"
							]
						},
						"description": "Reject a specific document with a reason. Teacher will be notified to re-upload."
					},
					"response": []
				},
				{
					"name": "Block Teacher",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"reason\": \"Suspected fraudulent documents\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/{{teacher_id}}/Block",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"{{teacher_id}}",
								"Block"
							]
						},
						"description": "Block a teacher account permanently. Optional reason can be provided."
					},
					"response": []
				},
				{
					"name": "Inactivate Teacher Subject",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/{{teacher_id}}/Subjects/{{teacher_subject_id}}/Inactivate",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"{{teacher_id}}",
								"Subjects",
								"{{teacher_subject_id}}",
								"Inactivate"
							]
						},
						"description": "Inactivate a teacher subject (blocks new courses; keeps approval status)"
					},
					"response": []
				},
				{
					"name": "Activate Teacher Subject",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/{{teacher_id}}/Subjects/{{teacher_subject_id}}/Activate",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"{{teacher_id}}",
								"Subjects",
								"{{teacher_subject_id}}",
								"Activate"
							]
						},
						"description": "Activate a previously inactivated subject (not for rejected — use Restore)"
					},
					"response": []
				},
				{
					"name": "Reject Teacher Subject",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"reason\": \"Subject qualification not verified.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/{{teacher_id}}/Subjects/{{teacher_subject_id}}/Reject",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"{{teacher_id}}",
								"Subjects",
								"{{teacher_subject_id}}",
								"Reject"
							]
						},
						"description": "Reject a teacher subject with reason; deactivates and blocks new courses"
					},
					"response": []
				},
				{
					"name": "Restore Teacher Subject",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept-Language",
								"value": "ar-EG",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/Api/V1/Admin/TeacherManagement/{{teacher_id}}/Subjects/{{teacher_subject_id}}/Restore",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"Api",
								"V1",
								"Admin",
								"TeacherManagement",
								"{{teacher_id}}",
								"Subjects",
								"{{teacher_subject_id}}",
								"Restore"
							]
						},
						"description": "Restore a rejected subject (approved + active, clears rejection reason)"
					},
					"response": []
				}
			],
			"description": "Command endpoints for document approval/rejection and account management"
		}
	]
}
